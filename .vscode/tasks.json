{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "PHPStan Analyse",
            "type": "shell",
            "command": "vendor/bin/phpstan analyse --error-format=raw",
            "group": "build",
            "problemMatcher": {
                "owner": "phpstan",
                "fileLocation": [
                    "relative",
                    "${workspaceFolder}"
                ],
                "pattern": {
                    "regexp": "^(.*):(\\d+):\\s+(.*)$",
                    "file": 1,
                    "line": 2,
                    "message": 3
                }
            }
        }
    ]
}
